# ── Supabase ─────────────────────────────────────────────────
# Project URL + anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by orchestrator logging/quota, billing webhook, LGPD export e admin.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── IA (lib/ai/registry.ts) ──────────────────────────────────
# Provider ativo: mock (default, dev sem custo) | echo (determinístico,
# testes) | anthropic (real).
AI_PROVIDER=mock
# Para usar a Edge Function Gemini em desenvolvimento/produção:
# AI_PROVIDER=gemini
# Necessário apenas com AI_PROVIDER=anthropic:
ANTHROPIC_API_KEY=your-anthropic-key
# Opcional; default claude-sonnet-5:
# ANTHROPIC_MODEL=claude-sonnet-5

# ── Billing (Stripe) — opcional em dev ───────────────────────
STRIPE_SECRET_KEY=your-stripe-secret
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# ── Rate limiting (Upstash) — opcional em dev ────────────────
# Sem estas vars, rate limiting é um no-op (não bloqueia nada) — mesma
# filosofia do AI_PROVIDER=mock: degrada graciosamente, nunca derruba o app.
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# ── Login com Google (RF-G01) — opcional ─────────────────────
# O client id/secret reais vivem só no Supabase Auth Dashboard
# (Authentication → Providers → Google), nunca neste repo. Só depois de
# configurar isso lá (ver docs/17-setup-google-oauth.md) é que faz sentido
# setar esta var como "true" — sem ela, o botão do Google fica "Em breve".
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# ── CAPTCHA (Cloudflare Turnstile) — opcional ────────────────
# A site key é pública; a secret key vive só no Supabase Auth Dashboard
# (Authentication → Attack Protection). Sem esta var, nenhum widget
# aparece e login/cadastro funcionam normalmente (degradação graciosa) —
# MAS: só ligue "Enable CAPTCHA protection" no dashboard depois de
# confirmar que o código já está enviando o token em produção, nunca antes
# (senão bloqueia todo mundo, inclusive você testando).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
