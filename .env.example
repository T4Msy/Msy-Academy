# ── Supabase ─────────────────────────────────────────────────
# Project URL + anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by the generate route to persist exams bypassing RLS when needed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI generation (n8n behind the API) ───────────────────────
# The browser NEVER calls this directly — only the server route does.
N8N_WEBHOOK_URL=https://your-n8n-host/webhook/gerar-prova
