# ── Supabase ─────────────────────────────────────────────────
# Project URL + anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by orchestrator logging/quota, billing webhook, LGPD export e admin.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── IA (lib/ai/registry.ts) ──────────────────────────────────
# Provider ativo: mock (default, dev sem custo) | echo (determinístico,
# testes) | anthropic (real).
AI_PROVIDER=mock
# Necessário apenas com AI_PROVIDER=anthropic:
ANTHROPIC_API_KEY=your-anthropic-key
# Opcional; default claude-sonnet-5:
# ANTHROPIC_MODEL=claude-sonnet-5

# ── Billing (Stripe) — opcional em dev ───────────────────────
STRIPE_SECRET_KEY=your-stripe-secret
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
